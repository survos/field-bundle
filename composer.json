{
    "name": "survos/field-bundle",
    "description": "Universal field/property metadata attributes for search, grid, and AI — #[Field], Widget enum, and FieldReader.",
    "type": "symfony-bundle",
    "license": "MIT",
    "keywords": ["symfony", "field", "metadata", "grid", "search", "meili", "datatables", "api-platform"],
    "autoload": {
        "psr-4": {
            "Survos\\FieldBundle\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Survos\\FieldBundle\\Tests\\": "tests/"
        }
    },
    "require": {
        "php": "^8.5",
        "survos/atlas-bundle": "^2.5",
        "symfony/config": "^8.1",
        "symfony/dependency-injection": "^8.1",
        "symfony/http-kernel": "^8.1",
        "symfony/string": "^8.1",
        "survos/kit-bundle": "^2.5"
    },
    "require-dev": {
        "phpunit/phpunit": "^13.0",
        "symfony/framework-bundle": "^8.1"
    },
    "suggest": {
        "symfony/ai-platform": "Read #[With] constraints (description, example, enum) from symfony/ai",
        "api-platform/core": "Read #[ApiProperty] and #[Parameter] filter declarations",
        "doctrine/orm": "Infer property types from #[ORM\\Column]",
        "survos/api-grid-bundle": "Render FieldDescriptors as DataTables ColumnControl grids",
        "survos/meili-bundle": "Sync FieldDescriptors to Meilisearch index settings"
    },
    "extra": {
        "symfony": {
            "require": "^8.0"
        }
    }
}
